# Ignore Python cache
__pycache__/
*.py[cod]
*$py.class
*.so

# Virtual environment
venv/
env/
ENV/

# Environment variables (IMPORTANT: Never commit credentials)
.env

# Database
real_estate.db
*.db

# Streamlit secrets (IMPORTANT: Never commit secrets)
.streamlit/secrets.toml

# IDE
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log

# OS
.DS_Store
Thumbs.db

# Google Drive OAuth (credentials.json has secrets; token.json is personal)
credentials.json
token.json
drive_file_id.txt

# Scraper runtime state (generated automatically, not part of source)
barrios_scrapeados_hoy.txt
barrio_page_history.json
current_scraper_urls.txt
urls_from_web.txt
model_metadata.json
