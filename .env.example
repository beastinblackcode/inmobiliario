# Twitter/X API — OAuth 1.0a
# Copia este archivo como .env y rellena con tus credenciales reales
# NUNCA subas el archivo .env a git (ya está en .gitignore)

TWITTER_API_KEY=aqui_tu_consumer_key
TWITTER_API_SECRET=aqui_tu_consumer_secret
TWITTER_ACCESS_TOKEN=aqui_tu_access_token
TWITTER_ACCESS_TOKEN_SECRET=aqui_tu_access_token_secret

# Scraping cost optimization
# FETCH_MODE: 'hybrid' (direct+proxy fallback), 'direct' (free only), 'proxy' (BrightData only)
FETCH_MODE=hybrid
# Seconds between direct requests (higher = safer, lower = faster)
DIRECT_REQUEST_DELAY=2.0
# Switch to proxy-only after N consecutive direct failures
DIRECT_FAIL_THRESHOLD=10
